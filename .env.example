# Copy to `.env` for local dev (see README).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Production URL for email confirmation links (https://…). Must match Supabase Auth → URL Configuration → Site URL.
# If unset, sign-up uses `window.location.origin` (fine when registering on the live site).
# VITE_SITE_URL=https://www.caracrew.org

# Optional: weekly digest email (`npm run digest:weekly`, GitHub Actions)
# RESEND_API_KEY=
# DIGEST_TO_EMAIL=you@example.com
# DIGEST_FROM_EMAIL=Caracrew <digest@yourdomain.com>
# DIGEST_SEASON_SLUG=2627
# PUBLIC_APP_URL=https://your-deployed-app.example.com   # include https:// (host-only works in CI — https added automatically)
